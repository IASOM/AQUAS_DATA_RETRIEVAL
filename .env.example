# Environment Variables Template
# Copy this file to .env and fill in your values

# Database Configuration
DB_SERVER=synw-aquas.sql.azuresynapse.net
DB_DATABASE=aquas
AUTH_MODE=ActiveDirectoryIntegrated

# Base Paths
# Set to the root directory of the project
BASE_DIR=C:/Users/Guillem/Downloads/AQUAS_INTEGRATION

# Reference data file
UP_RS_FILE=C:/Users/Guillem/Downloads/AQUAS_INTEGRATION/UPperRS.xlsx

# Optional shared selection files
SELECTED_RS_FILE=C:/Users/Guillem/Downloads/AQUAS_INTEGRATION/selections/selected_rs.csv
SELECTED_UP_FILE=C:/Users/Guillem/Downloads/AQUAS_INTEGRATION/selections/selected_up.csv

# Optional diagnosis-only selection file
SELECTED_DIAGNOSIS_CODES_FILE=C:/Users/Guillem/Downloads/AQUAS_INTEGRATION/selections/selected_diagnosis_codes.csv
MAX_DIAGNOSIS_FEATURES=200000

# Logging
LOG_LEVEL=INFO
